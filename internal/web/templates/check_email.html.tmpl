{{define "content"}}
<div class="max-w-md mx-auto mt-16 text-center">
    <div class="bg-white shadow rounded-lg p-8">
        <h1 class="text-2xl font-bold text-gray-900 mb-4">Check your email</h1>
        <p class="text-gray-600 mb-6">
            If that address is registered, we've sent a sign-in link. The link expires in {{.TokenExpiry}} minutes.
        </p>
        <a href="/login" class="text-indigo-600 hover:text-indigo-800 underline">Back to sign in</a>
    </div>
</div>
{{end}}
