{{define "content"}}
<div class="max-w-md mx-auto mt-16 text-center">
    <div class="bg-white shadow rounded-lg p-8">
        <h1 class="text-2xl font-bold text-gray-900 mb-4">Confirm Sign In</h1>
        <p class="text-gray-600 mb-6">Click the button below to complete sign in.</p>
        <form method="POST" action="/auth/verify">
            <input type="hidden" name="token" value="{{.Token}}">
            <button type="submit" class="bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 transition-colors">
                Sign in
            </button>
        </form>
    </div>
</div>
{{end}}
