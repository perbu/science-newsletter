{{if .Topics}}
<div id="topics-table">
    <table class="w-full text-sm">
        <thead>
            <tr class="text-left text-gray-500 border-b">
                <th class="py-2">Topic</th>
                <th class="py-2">Subfield</th>
                <th class="py-2">Field</th>
                <th class="py-2 text-center">Source</th>
                <th class="py-2 text-right">Score</th>
                <th class="py-2 text-right w-20"></th>
            </tr>
        </thead>
        <tbody>
            {{range .Topics}}
            <tr class="border-b border-gray-100" id="topic-row-{{.ID}}">
                <td class="py-2">{{.Name}}</td>
                <td class="py-2 text-gray-500">{{.Subfield}}</td>
                <td class="py-2 text-gray-500">{{.Field}}</td>
                <td class="py-2 text-center">
                    {{if eq .Source "manual"}}
                    <span class="text-xs px-2 py-0.5 rounded bg-amber-100 text-amber-700">manual</span>
                    {{else if eq .Source "llm"}}
                    <span class="text-xs px-2 py-0.5 rounded bg-violet-100 text-violet-700">llm</span>
                    {{else}}
                    <span class="text-xs px-2 py-0.5 rounded bg-blue-100 text-blue-700">openalex</span>
                    {{end}}
                </td>
                <td class="py-2 text-right">
                    <input type="number" step="0.001" min="0" max="1000"
                        value="{{printf "%.3f" .Score}}"
                        name="score"
                        hx-put="/researchers/{{$.Researcher.ID}}/topics/{{.ID}}/score"
                        hx-trigger="change"
                        hx-swap="none"
                        class="w-20 text-right font-mono text-sm border border-gray-200 rounded px-1 py-0.5">
                </td>
                <td class="py-2 text-right">
                    <button
                        hx-delete="/researchers/{{$.Researcher.ID}}/topics/{{.ID}}"
                        hx-target="#topic-row-{{.ID}}"
                        hx-swap="outerHTML"
                        hx-confirm="Remove topic '{{.Name}}'?"
                        class="text-red-500 hover:text-red-700 text-xs px-2 py-1">
                        Remove
                    </button>
                </td>
            </tr>
            {{end}}
        </tbody>
    </table>
</div>
{{else}}
<p class="text-gray-500 text-sm" id="topics-table">No topics yet. Sync the profile or add topics manually.</p>
{{end}}
