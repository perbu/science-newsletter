{{define "content"}}
<div class="max-w-lg mx-auto">
    <h1 class="text-2xl font-bold text-gray-800 mb-2">Welcome!</h1>
    <p class="text-gray-600 mb-6">Select your researcher profile to get started.</p>

    {{if not .Researchers}}
    <p class="text-gray-500 mb-4">No researcher profiles exist yet.</p>
    <a href="/researchers/new" class="bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700">
        Add Researcher
    </a>
    {{else}}
    <div class="space-y-3 mb-6">
        {{range .Researchers}}
        <form method="POST" action="/auth/pick-researcher" class="bg-white rounded-lg shadow p-4 flex items-center justify-between">
            <div>
                <span class="font-semibold text-gray-800">{{.Name}}</span>
                <p class="text-sm text-gray-500">{{.Affiliation}}</p>
            </div>
            <input type="hidden" name="researcher_id" value="{{.ID}}">
            <button type="submit" class="bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 text-sm">
                This is me
            </button>
        </form>
        {{end}}
    </div>
    <a href="/researchers/new" class="text-indigo-600 hover:underline text-sm">
        Add a new researcher
    </a>
    {{end}}
</div>
{{end}}
