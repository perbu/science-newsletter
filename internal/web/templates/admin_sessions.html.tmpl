{{define "content"}}
<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-900">Active Sessions</h1>
        <a href="/admin" class="text-sm text-indigo-600 hover:text-indigo-800">Back to Dashboard</a>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        <div id="sessions-table">
            {{template "sessions-table" .}}
        </div>
    </div>
</div>
{{end}}

{{define "sessions-table"}}
{{if .Sessions}}
<table class="min-w-full text-sm">
    <thead>
        <tr class="border-b text-left text-gray-500">
            <th class="pb-2 pr-4">ID</th>
            <th class="pb-2 pr-4">Email</th>
            <th class="pb-2 pr-4">Created</th>
            <th class="pb-2 pr-4">Expires</th>
            <th class="pb-2">Actions</th>
        </tr>
    </thead>
    <tbody>
        {{range .Sessions}}
        <tr class="border-b border-gray-100">
            <td class="py-2 pr-4 text-gray-600">{{.ID}}</td>
            <td class="py-2 pr-4">{{.Email}}</td>
            <td class="py-2 pr-4 text-gray-600">{{.CreatedAt.Format "2006-01-02 15:04"}}</td>
            <td class="py-2 pr-4 text-gray-600">{{.ExpiresAt.Format "2006-01-02 15:04"}}</td>
            <td class="py-2">
                <button hx-delete="/admin/sessions/{{.ID}}"
                        hx-target="#sessions-table"
                        hx-swap="innerHTML"
                        hx-confirm="Revoke this session?"
                        class="text-xs bg-red-600 hover:bg-red-500 text-white px-2 py-1 rounded">
                    Revoke
                </button>
            </td>
        </tr>
        {{end}}
    </tbody>
</table>
{{else}}
<p class="text-gray-500">No active sessions.</p>
{{end}}
{{end}}
