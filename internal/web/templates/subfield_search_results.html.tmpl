{{if .Results}}
<div class="space-y-1">
    {{range .Results}}
    <label class="flex items-center gap-2 text-sm text-gray-700 py-1 px-2 rounded hover:bg-gray-50">
        <input type="checkbox"
            {{if .Selected}}checked{{end}}
            hx-post="/researchers/{{$.ResearcherID}}/field-selection"
            hx-swap="none"
            hx-vals='js:{
                "level": "subfield",
                "openalex_id": "{{.SubfieldID}}",
                "display_name": "{{.SubfieldName}}",
                "action": event.target.checked ? "add" : "remove"
            }'
            class="rounded border-gray-300">
        <span>{{.SubfieldName}}</span>
        <span class="text-xs text-gray-400">{{.FieldName}} &middot; {{.DomainName}}</span>
    </label>
    {{end}}
</div>
{{else}}
<p class="text-sm text-gray-400 py-1">No matching subfields.</p>
{{end}}
